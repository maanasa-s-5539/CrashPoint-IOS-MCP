# CrashPoint iOS MCP — Environment Variables
# Copy this file to .env and fill in your values.

# Required: path to the ParentHolderFolder
CRASH_ANALYSIS_PARENT=/path/to/ParentHolderFolder

# Recommended: path to your .dSYM bundle (required for symbolication)
DSYM_PATH=/path/to/MyApp.dSYM

# Recommended: path to your .app bundle
APP_PATH=/path/to/MyApp.app

# Optional: app binary name (used to filter frames in reports)
APP_NAME=MyApp

# Optional: override directory searched for .xccrashpoint files
CRASH_INPUT_DIR=

# Optional: comma-separated version filter for exports
CRASH_VERSIONS=

# Optional: path to master/live branch checkout (creates CurrentMasterLiveBranch symlink)
MASTER_BRANCH_PATH=/path/to/app-ios-master

# Optional: path to development branch checkout (creates CurrentDevelopmentBranch symlink)
DEV_BRANCH_PATH=/path/to/app-ios-dev

# Optional: Zoho Cliq channel incoming webhook URL (the only Cliq integration method)
# Format: https://cliq.zoho.in/company/{org_id}/api/v2/channelsbyname/{channel_name}/message
ZOHO_CLIQ_WEBHOOK_URL=

# ── Zoho Projects MCP Integration (for CLI report-zoho + MCP tool) ─────────
# MCP Server URL — create one at https://mcp.zoho.com, add Zoho Projects tools, copy the URL
ZOHO_PROJECTS_MCP_URL=

# Portal and Project IDs — discover via Claude ("list my Zoho Projects portals") or Zoho Projects UI
ZOHO_PROJECTS_PORTAL_ID=
ZOHO_PROJECTS_PROJECT_ID=

# ── Zoho Bug Field Value IDs ───────────────────────────────────────────────
# These are unique to your portal/project. Discover them by asking Claude:
#   "Using Zoho Projects, list all bug fields and their allowed values for my project"
#
# Status IDs (map CrashPoint fix status → Zoho bug status)
ZOHO_BUG_STATUS_OPEN=
ZOHO_BUG_STATUS_FIXED=
#
# Severity IDs (map crash exception type → Zoho bug severity)
ZOHO_BUG_SEVERITY_CRITICAL=
ZOHO_BUG_SEVERITY_MAJOR=
ZOHO_BUG_SEVERITY_MINOR=
