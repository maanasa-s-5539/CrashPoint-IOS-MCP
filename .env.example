# CrashPoint iOS MCP — Environment Variables
#
# Only CRASH_ANALYSIS_PARENT is required as an environment variable.
# It tells the server where to find crashpoint.config.json, which contains
# all other configuration values.
#
# All other settings (DSYM_PATH, Zoho keys, etc.) should be
# configured in <CRASH_ANALYSIS_PARENT>/crashpoint.config.json instead.
# See crashpoint.config.example.json for the full list of config keys.

# Required: path to the ParentHolderFolder (where crashpoint.config.json lives)
CRASH_ANALYSIS_PARENT=/path/to/ParentHolderFolder
