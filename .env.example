# ==============================================================================
# CrashpointMCP — Environment Configuration
# Copy to .env and fill in your paths. .env is gitignored.
# ==============================================================================

# -- Parent Folder (all subfolders auto-resolve from this) ---------------------
CRASH_ANALYSIS_PARENT=/path/to/ParentHolderFolder

# -- Symlink Targets ----------------------------------------------------------
MASTER_BRANCH_PATH=/path/to/your/xcode/workspace/master
DEV_BRANCH_PATH=/path/to/your/xcode/workspace/development

# -- dSYM and .app Paths (symlinked into ParentHolderFolder as dSYM_File and app_File)
DSYM_PATH=/path/to/MyApp.dSYM
APP_PATH=/path/to/MyApp.app
APP_NAME=MyApp

# -- Capability 1: .xccrashpoint Export ----------------------------------------
# Where to search for .xccrashpoint files (default: ~/Library/Logs/DiagnosticReports)
CRASH_INPUT_DIR=
# Filter versions (comma-separated). Leave blank for ALL.
CRASH_VERSIONS=

# -- Zoho Cliq -----------------------------------------------------------------
ZOHO_CLIQ_WEBHOOK_URL=
ZOHO_CLIQ_BOT_WEBHOOK_URL=
