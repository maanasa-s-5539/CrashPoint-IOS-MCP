# Byte-compiled / optimized / DLL files (kept minimal in case of any Python tooling)
__pycache__/
*.py[cod]

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript build output
dist/

