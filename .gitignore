.env
.env.local
.env.*
!.env.example

# OS & IDE
.DS_Store
.vscode/
.idea/

# Crash data (local only — never commit crash logs)
ParentHolderFolder/
BasicCrashLogsFolder/
SymbolicatedCrashLogsFolder/
*.crash
*.ips
crash_report_*.json
fix_status.json
