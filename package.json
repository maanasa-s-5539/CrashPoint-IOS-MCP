{
  "name": "@maanasa-s-5539/crashpoint-ios-mcp",
  "version": "1.0.0",
  "description": "Standalone MCP server for iOS/macOS crash log export, symbolication, analysis & CSV reporting.",
  "license": "MIT",
  "scripts": {
    "build": "tsc --declaration --emitDeclarationOnly --outDir dist && esbuild src/core-server.ts --bundle --platform=node --target=node18 --outfile=dist/core-server.js && esbuild src/cli/index.ts --bundle --platform=node --target=node18 --outfile=dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/core-server.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/core-server.js",
      "types": "./dist/index.d.ts"
    },
    "./core/crashAnalyzer": {
      "types": "./dist/core/crashAnalyzer.d.ts",
      "import": "./dist/core/crashAnalyzer.js"
    },
    "./core/crashExporter": {
      "types": "./dist/core/crashExporter.d.ts",
      "import": "./dist/core/crashExporter.js"
    },
    "./core/symbolicator": {
      "types": "./dist/core/symbolicator.d.ts",
      "import": "./dist/core/symbolicator.js"
    },
    "./core/csvExporter": {
      "types": "./dist/core/csvExporter.d.ts",
      "import": "./dist/core/csvExporter.js"
    },
    "./core/setup": {
      "types": "./dist/core/setup.d.ts",
      "import": "./dist/core/setup.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./state/fixTracker": {
      "types": "./dist/state/fixTracker.d.ts",
      "import": "./dist/state/fixTracker.js"
    },
    "./state/processedManifest": {
      "types": "./dist/state/processedManifest.d.ts",
      "import": "./dist/state/processedManifest.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "import": "./dist/state/index.js"
    },
    "./pathSafety": {
      "types": "./dist/pathSafety.d.ts",
      "import": "./dist/pathSafety.js"
    }
  },
  "files": [
    "dist/"
  ],
  "bin": {
    "crashpoint-ios-core": "dist/core-server.js",
    "crashpoint-ios-cli": "dist/cli.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maanasa-s-5539/CrashPoint-IOS-MCP.git"
  },
  "keywords": [
    "iOS",
    "macOS",
    "crash",
    "symbolication",
    "atos",
    "MCP",
    "Xcode"
  ],
  "author": "maanasa-s-5539",
  "bugs": {
    "url": "https://github.com/maanasa-s-5539/CrashPoint-IOS-MCP/issues"
  },
  "homepage": "https://github.com/maanasa-s-5539/CrashPoint-IOS-MCP#readme"
}
